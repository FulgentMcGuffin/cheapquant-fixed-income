# Optional overrides — copy to .env and adjust paths / API keys.

# Config file (default: config/cqfi.yaml)
# CQFI_CONFIG=./config/cqfi.yaml

# Per-path overrides (take precedence over the YAML file)
# CQFI_INPUT_DB=C:\data\sqlitedb\input_data.db
# CQFI_INPUT_SEMANTICS=D:\Code\mcp_data\semantics\input_data.yaml
# CQFI_CACHE_DB=./data/cache/active_cache.db
# CQFI_CACHE_SEMANTICS=./semantics
# CQFI_SESSIONS_DIR=./data/sessions

# LLM mode (mcp-data) — required for --llm / --llm-single-shot
# ANTHROPIC_API_KEY=sk-ant-...

# LangSmith tracing is OFF by default for cqfi (avoids 403 noise from global
# LANGCHAIN_TRACING_V2 settings without a valid LangSmith key). Opt in:
# CQFI_LANGSMITH=1
# LANGCHAIN_API_KEY=lsv2_...
