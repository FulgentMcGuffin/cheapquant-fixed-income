# Copy to .env and adjust. Loaded by config.py (does not override existing shell env).
#
# Precedence (low → high): config/cqfi.yaml → .env CQFI_* overrides → --config / CQFI_CONFIG

# ── Secrets (typical .env contents) ──────────────────────────────────────────

# LLM mode (mcp-data) — required for --llm / --llm-single-shot
# ANTHROPIC_API_KEY=sk-ant-...

# LangSmith tracing is OFF by default for cqfi (avoids 403 noise from global
# LANGCHAIN_TRACING_V2 without a valid LangSmith key). Opt in:
# CQFI_LANGSMITH=1
# LANGCHAIN_API_KEY=lsv2_...

# ── Optional overrides (uncomment only when this machine differs from cqfi.yaml) ─

# Alternate config file
# CQFI_CONFIG=./config/cqfi.yaml

# Path overrides (take precedence over config/cqfi.yaml)
# CQFI_YCS_DB=D:/data/duckdb/ycs_data.duckdb
# CQFI_YCS_SEMANTICS=./semantics/ycs_data.yaml
# CQFI_BOND_ANALYTICS_DB=D:/data/duckdb/bond_analytics.duckdb
# CQFI_CACHE_DB=./data/cache/active_cache.db
# CQFI_CACHE_SEMANTICS=./semantics
# CQFI_SESSIONS_DIR=./data/sessions

# Settings overrides
# CQFI_WRITE_TO_BOND_ANALYTICS_DB=true
